                        "uuid": "f308031852024b91957262615462536f",
                        "name": "Filer Update Available",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "1.3.6.1.4.1.42040.1.5.0",
                        "key": "nasuni.filer.update_available",
                        "value_type": "CHAR",
                        "triggers": [
                            {
                                "uuid": "4058c85287434421a6d7788bd4de7641",
                                "expression": "last(/Nasuni Filer SNMP/nasuni.filer.update_available)>0",
                                "name": "Nasuni: Filer has Update available",
                                "priority": "WARNING",
                                "description": "Nasuni: Filer has Update available"
                            }
                        ]
                    },
                    {
                        "uuid": "d108031852024b91957262615462536f",
                        "name": "Filer Uptime",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "1.3.6.1.4.1.42040.1.4.0",
                        "key": "nasuni.filer.uptime",
                        "units": "uptime",
                        "preprocessing": [
                            {
                                "type": "MULTIPLIER",
                                "parameters": [
                                    "0.01"
                                ]
                            }
                        ],
                        "triggers": [
                            {
                                "uuid": "a1b2c3d4e5f6478899aabbccddeeff01",
                                "expression": "last(/Nasuni Filer SNMP/nasuni.filer.uptime)<10m",
                                "name": "Nasuni: Filer has recently rebooted",
                                "priority": "INFO"
                            }
                        ]
                    },
                    {
                        "uuid": "c108031852024b91957262615462536e",
                        "name": "Filer Version",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "1.3.6.1.4.1.42040.1.2.0",
                        "key": "nasuni.filer.version",
                        "delay": "1h",
                        "value_type": "CHAR"
                    },
                    {
                        "uuid": "847cddf7d9bd41f9aa42dabac2b18bf3",
                        "name": "RAID Array Errors",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "1.3.6.1.4.1.42040.1.102.7.0",
                        "key": "nasuni.health.raid_errors",
                        "delay": "60s",
                        "value_type": "CHAR",
                        "triggers": [
                            {
                                "uuid": "f32f4a61c893450399fdf80aa42c224e",
                                "expression": "last(/Nasuni Filer SNMP/nasuni.health.raid_errors)<0",
                                "name": "Nasuni: RAID Array Error detected",
                                "priority": "DISASTER",
                                "description": "Nasuni: RAID Array Error detected"
                            }
                        ]
                    }
                ],
                "discovery_rules": [
                    {
                        "uuid": "f208031852024b91957262615462540e",
                        "name": "Volume Discovery",
                        "type": "SNMP_AGENT",
                        "snmp_oid": "discovery[{#VOLNAME},1.3.6.1.4.1.42040.2.2.1.2]",
                        "key": "nasuni.volume.discovery",
                        "delay": "1h",
                        "status": "ENABLED",
                        "item_prototypes": [
                            {
                                "uuid": "3c08031852024b91957262615462543f",
                                "name": "Volume {#VOLNAME}: Quota Bytes",
                                "type": "SNMP_AGENT",
                                "snmp_oid": "1.3.6.1.4.1.42040.2.2.1.19.{#SNMPINDEX}",
                                "key": "nasuni.vol.quota[{#VOLNAME}]",
                                "units": "B"
                            },
                            {
                                "uuid": "1a08031852024b91957262615462541f",
                                "name": "Volume {#VOLNAME}: Status",
                                "type": "SNMP_AGENT",
                                "snmp_oid": "1.3.6.1.4.1.42040.2.2.1.5.{#SNMPINDEX}",
                                "key": "nasuni.vol.status[{#VOLNAME}]",
                                "delay": "5m",
                                "value_type": "CHAR",
                                "trigger_prototypes": [
                                    {
                                        "uuid": "2b08031852024b91957262615462542e",
                                        "expression": "last(/Nasuni Filer SNMP/nasuni.vol.status[{#VOLNAME}])<>\"Online\" and last(/Nasuni Filer SNMP/nasuni.vol.status[{#VOLNAME}])<>\"\"",
                                        "name": "Nasuni: Volume {#VOLNAME} is NOT Online (Status: {ITEM.VALUE})",
                                        "priority": "WARNING"
                                    }
                                ]
                            },
                            {
                                "uuid": "4d08031852024b91957262615462544d",
                                "name": "Volume {#VOLNAME}: Unprotected Data",
                                "type": "SNMP_AGENT",
                                "snmp_oid": "1.3.6.1.4.1.42040.2.2.1.7.{#SNMPINDEX}",
                                "key": "nasuni.vol.unprotected[{#VOLNAME}]",
                                "units": "B",
                                "trigger_prototypes": [
                                    {
                                        "uuid": "5e08031852024b91957262615462545e",
                                        "expression": "last(/Nasuni Filer SNMP/nasuni.vol.unprotected[{#VOLNAME}])>10737418240",
                                        "name": "Nasuni: Volume {#VOLNAME} has over 10GB of unprotected data",
                                        "priority": "WARNING"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ],
        "triggers": [
            {
                "uuid": "2cfefbdeb3b34261aec4dac1a0d70f6a",
                "expression": "last(/Nasuni Filer SNMP/nasuni.cache.used) / last(/Nasuni Filer SNMP/nasuni.cache.total) * 100 > 95",
                "name": "Nasuni: Cache usage is over 95%",
                "priority": "HIGH",
                "description": "Nasuni: Cache usage is over 95%"
            }
        ]
    }
}